{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Peekoo",
  "version": "0.1.0",
  "identifier": "com.peekoo.desktop",
  "build": {
    "beforeDevCommand": "cd ../desktop-ui && bun run dev",
    "beforeBuildCommand": "cd ../desktop-ui && bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../desktop-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Peekoo",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: localhost:*; img-src 'self' asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost",
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
