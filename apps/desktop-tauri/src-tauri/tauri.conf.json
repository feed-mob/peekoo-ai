{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Peekoo",
  "version": "0.1.28",
  "identifier": "com.peekoo.desktop",
  "build": {
    "beforeDevCommand": "cd ../desktop-ui && bun run dev",
    "beforeBuildCommand": "cd ../desktop-ui && bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../desktop-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Peekoo",
        "width": 200,
        "height": 250,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/peekoo-agent-acp"
    ],
    "resources": [
      "resources/**/*"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5MjBGREMxMkM0RjdBNkIKUldScmVrOHN3ZjBnaVN5KzVNd3RHM01VOUYzUVNlam9EOHJGU01YNnpEeWhrdnQ4ZlM3aFMvU3QK",
      "endpoints": [
        "https://github.com/feed-mob/peekoo-ai/releases/latest/download/latest.json"
      ]
    }
  }
}
