{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Peekoo",
  "version": "0.1.0",
  "identifier": "com.peekoo.desktop",
  "build": {
    "beforeDevCommand": "cd ../desktop-ui && npm run dev",
    "beforeBuildCommand": "cd ../desktop-ui && npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../desktop-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Peekoo",
        "width": 200,
        "height": 250,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "dataDirectory": "webview-data"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: localhost:*; img-src 'self' asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost; font-src 'self' https://fonts.bunny.net; style-src 'self' 'unsafe-inline' https://fonts.bunny.net",
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5MjBGREMxMkM0RjdBNkIKUldScmVrOHN3ZjBnaVN5KzVNd3RHM01VOUYzUVNlam9EOHJGU01YNnpEeWhrdnQ4ZlM3aFMvU3QK",
      "endpoints": [
        "https://github.com/feed-mob/peekoo-ai/releases/latest/download/latest.json"
      ]
    }
  }
}