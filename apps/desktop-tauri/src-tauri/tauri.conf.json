{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Peekoo",
  "version": "0.1.0",
  "identifier": "com.peekoo.desktop",
  "build": {
    "beforeDevCommand": "cd ../desktop-ui && bun run dev",
    "beforeBuildCommand": "cd ../desktop-ui && bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../desktop-ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Peekoo",
        "width": 200,
        "height": 250,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "dataDirectory": "webview-data"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: localhost:*; img-src 'self' asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost; font-src 'self' https://fonts.bunny.net; style-src 'self' 'unsafe-inline' https://fonts.bunny.net",
      "dangerousDisableAssetCspModification": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
